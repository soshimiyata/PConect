        <% end %>
      </li>
      <li>
        <%= link_to posts_path, class: 'nav-link' do %>
          <i class="fas fa-file-alt"></i>
          Posts
        <% end %>
      </li>
      <li>
        <%= link_to new_post_path, class: 'nav-link' do %>
