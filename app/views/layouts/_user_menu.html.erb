    <div class="notification-icon d-flex align-items-center justify-content-center"> <!-- 中央揃えのためのスタイルを追加 -->
      <%= link_to notifications_path do %>
        <% if unchecked_notifications.any? %>
          <i class="fas fa-bell fa-2x" style="color: yellow;"></i><!-- 未読マーク -->
        <% else %>
          <i class="fas fa-bell fa-2x" style="color: white;"></i> <!-- 既読マーク -->
        <% end %>
      <% end %>
    </div>
  </li>
  <li class="dropdown" style="margin-left: 30px;">
    <a href="#"
      class="dropdown-toggle"
      data-toggle="dropdown"
      role="button"
      aria-haspopup="true"
      aria-expanded="false">
      <i class="fas fa-bars fa-lg"></i>
    </a>
    <ul class="dropdown-menu dropdown-menu-right">
      <li>
        <%= link_to root_path, class: 'nav-link', data: { "turbolinks" => false } do %>
          <i class="fas fa-home"></i>
          Home
        <% end %>
      </li>
      <li>
        <%= link_to users_path, class: 'nav-link' do %>
          <i class="fas fa-users"></i>
