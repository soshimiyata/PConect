<nav class="navbar navbar-expand-lg navbar-dark bg-dark" style="height: 70px;"> <!-- ヘッダーの高さを70pxに設定 -->
  <div class="container">
    <% if user_signed_in? %>
    <h1><i class="fa-solid fa-desktop text-white"></i><%= link_to "PConect", root_path, style: 'color: white;', data: { "turbolinks" => false } %></h1>
    <% elsif request.fullpath.include?("/admin") %>
    <% else %>
    <h1><i class="fa-solid fa-desktop text-white"></i><%= link_to "PConect", root_path, style: 'color: white;', data: { "turbolinks" => false } %></h1>
    <% end %>

    <% if admin_signed_in? %>
      <%= render 'layouts/admin_menu' %>
    <% elsif request.fullpath.include?("/admin") %> <!--adminがurlに含まれていて、ログインしてない場合-->
      <%= render 'layouts/admin_guest_menu' %>
    <% elsif user_signed_in? %>
      <%= render 'public/searches/form' %>
      <%= render 'layouts/user_menu' %>
    <% else %>
      <%= render 'layouts/guest_menu' %>
    <% end %>
  </div>
</nav>
